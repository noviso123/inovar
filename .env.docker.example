# ==============================================================
# INOVAR - Variáveis de Ambiente para Docker (EXEMPLO)
# Copie este arquivo para .env.docker e configure os valores
# ==============================================================

# Ambiente
ENVIRONMENT=production

# Servidor
PORT=8080
APP_PORT=8080

# Banco de dados (path dentro do container - NÃO ALTERE)
DATABASE_URL=/app/data/db/inovar.db

# Segurança JWT
# OBRIGATÓRIO! Gere com: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_EXPIRE_MINUTES=60
REFRESH_EXPIRE_DAYS=7

# CORS - Em produção, especifique o domínio exato: https://seudominio.com
CORS_ORIGINS=*

# Frontend URL (para links em emails de reset de senha)
FRONTEND_URL=http://localhost:8080

# Upload de arquivos (path dentro do container - NÃO ALTERE)
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE=10485760

# Caminho do frontend compilado (NÃO ALTERE)
FRONTEND_DIST=/app/frontend/dist

LOCK_TIMEOUT_SECS=300
CONFIRM_DAYS=7

# SMTP (deixe vazio para desabilitar envio de emails)
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=seu@gmail SMTP_PASSWORD=app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@inovar.com
