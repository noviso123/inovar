# ============================================================
# INOVAR - Docker Environment Configuration
# ============================================================
# Copy this file to .env.docker and fill in your values
# Usage: docker compose --env-file .env.docker up -d
# ============================================================

# Server
ENVIRONMENT=production
PORT=8080

# Database (SQLite - path inside container)
DATABASE_URL=/app/data/db/inovar.db

# JWT Security (CHANGE THIS!)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING
JWT_EXPIRE_MINUTES=60
REFRESH_EXPIRE_DAYS=7

# CORS (use '*' for all or restrict to your domain)
CORS_ORIGINS=*

# ============================================================
# 🔴 IMPORTANT: Set this to your PUBLIC VPS URL
# This URL is used in ALL email links and buttons
# ============================================================
FRONTEND_URL=https://seu-dominio.com

# Default password for new users
DEFAULT_PASSWORD=123456

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@seudominio.com

# Upload limits
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/app/data/uploads
