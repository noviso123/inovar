# INOVAR - Configuração de Produção (Docker)

# Servidor
ENVIRONMENT=production
PORT=8080
APP_PORT=8080
JWT_SECRET=mude-isto-em-producao-uma-chave-bem-longa-e-segura

# Banco de Dados (Supabase/Postgres)
# Se quiser usar SQLite local, comente as linhas de Supabase e use a DATABASE_URL do example
DATABASE_URL=postgres://postgres:password@db.supabase.co:5432/postgres

# Storage / Supabase (S3 Bridge)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=xxxx
AWS_ACCESS_KEY_ID=xxxx
AWS_SECRET_ACCESS_KEY=xxxx
AWS_REGION=sa-east-1
AWS_BUCKET=uploads
AWS_ENDPOINT=https://xxxx.supabase.co/storage/v1/s3

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=usuario@gmail.com
SMTP_PASSWORD=senha-ou-app-password
SMTP_FROM=Sistema Inovar <noreply@inovar.site>

# Frontend
FRONTEND_DIST=/app/client/dist
VITE_API_URL=https://seu-dominio.com.br/api
