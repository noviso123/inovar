# INOVAR - Configuração de Produção (Docker)

# Servidor
ENVIRONMENT=production
PORT=8080
APP_PORT=8080
JWT_SECRET=mude-isto-em-producao-uma-chave-bem-longa-e-segura

# Banco de Dados (SQLite local)
DATABASE_URL=/app/data/db/inovar.db

# Upload de Arquivos (local)
UPLOAD_DIR=/app/data/uploads

# Frontend
FRONTEND_DIST=/app/client/dist

# CORS (ajuste para seu domínio)
CORS_ORIGINS=*

# Email (SMTP) - opcional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=usuario@gmail.com
SMTP_PASSWORD=senha-ou-app-password
SMTP_FROM=Sistema Inovar <noreply@inovar.site>
