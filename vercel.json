{
    "version": 2,
    "builds": [
        {
            "src": "inovar-gestao/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "inovar-gestao/dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/inovar-gestao/dist/index.html"
        }
    ]
}
