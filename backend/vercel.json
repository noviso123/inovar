{
    "version": 2,
    "builds": [
        {
            "src": "api/index.go",
            "use": "@vercel/go"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.go"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "env": {
        "GO_IMPORT_PATH": "github.com/inovar/backend"
    }
}
