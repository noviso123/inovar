# INOVAR Environment Variables
# Copy this file to .env and adjust values

# ===========================================
# Environment (development, staging, production)
# ===========================================
ENVIRONMENT=development

# ===========================================
# Server
# ===========================================
PORT=8080

# ===========================================
# Database (SQLite for dev, PostgreSQL for production)
# ===========================================
DATABASE_URL=./storage/inovar.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/inovar?sslmode=require

# ===========================================
# Security - JWT
# IMPORTANT: Set a strong secret in production!
# Generate with: openssl rand -hex 32
# ===========================================
# In development, this is optional (a random secret will be generated)
# In production/staging, this is REQUIRED!
JWT_SECRET=
JWT_EXPIRE_MINUTES=60
REFRESH_EXPIRE_DAYS=7

# ===========================================
# CORS
# ===========================================
# Use specific origins in production, e.g.: https://app.inovar.com
CORS_ORIGINS=*

# ===========================================
# Frontend URL (for email links)
# ===========================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# SMTP Email Configuration
# Required for password reset emails in production
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@inovar.com

# Example for Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Example for SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# ===========================================
# File uploads
# ===========================================
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE=10485760

# ===========================================
# Application Settings
# ===========================================
LOCK_TIMEOUT_SECS=300
CONFIRM_DAYS=7

# ===========================================
# NFS-e Nacional (GOV.BR)
# ===========================================
# O sistema Inovar integra com o NFS-e Nacional (https://nfse.gov.br)
# Em vigor para Serra-ES, Vitória-ES e outros municípios aderentes.
#
# URLs da API:
# - Produção: https://sefin.nfse.gov.br/SefinNacional
# - Homologação: https://sefin.producaorestrita.nfse.gov.br/API/SefinNacional
#
# Requisitos:
# 1. Certificado Digital ICP-Brasil A1 (arquivo .pfx ou .p12)
# 2. Inscrição Municipal no município
# 3. Configuração fiscal no sistema (Menu: Configurações > Fiscal)
#
# Para usar em produção:
# 1. Faça upload do certificado A1 no sistema (Menu: Fiscal > Certificado)
# 2. Configure os dados fiscais (CNAE, Código Serviço, Alíquota ISS)
# 3. Altere para AMBIENTE=PRODUCAO nas configurações fiscais
#
# Códigos IBGE dos municípios:
# - Serra-ES: 3205002
# - Vitória-ES: 3205309
# - Vila Velha-ES: 3205200
# - Cariacica-ES: 3201308
