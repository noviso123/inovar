# INOVAR Environment Variables
# Copy this file to .env and adjust values

PORT=8080
DATABASE_URL=./inovar.db
JWT_SECRET=inovar-super-secret-key-change-in-production
CORS_ORIGINS=*

# SMTP (optional - for email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@inovar.com

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Timeouts
LOCK_TIMEOUT_SECS=300
CONFIRM_DAYS=7
